{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zk-voting.example/schemas/v1-fort-worth-dao-member.json",
  "title": "FortWorthDAOMembershipCredential",
  "type": "object",
  "required": [
    "membershipId",
    "membershipStatus",
    "jurisdiction",
    "memberSince",
    "votingEligible"
  ],
  "properties": {
    "membershipId": {
      "type": "string",
      "minLength": 1
    },
    "membershipStatus": {
      "type": "string",
      "enum": ["active", "suspended", "revoked"]
    },
    "jurisdiction": {
      "type": "string",
      "minLength": 1
    },
    "memberSince": {
      "type": "integer"
    },
    "votingEligible": {
      "type": "boolean"
    },
    "membershipTier": {
      "type": "string"
    },
    "committee": {
      "type": "string"
    },
    "expirationDate": {
      "type": "integer"
    }
  },
  "additionalProperties": false
}
