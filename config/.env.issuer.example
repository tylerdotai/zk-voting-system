# Polygon ID Issuer (Phase 2) example values
# Copy this into your issuer-node environment files as needed.

ISSUER_SERVER_URL=https://your-public-issuer-url.example
ISSUER_API_AUTH_USER=demo-issuer
ISSUER_API_AUTH_PASSWORD=change-me

ISSUER_UI_AUTH_USERNAME=demo-ui
ISSUER_UI_AUTH_PASSWORD=change-me
ISSUER_UI_INSECURE=false

# Demo KMS providers (local). For production, move to vault/KMS.
ISSUER_KMS_BJJ_PROVIDER=local
ISSUER_KMS_ETH_PROVIDER=local

# Optional chain resolver notes (set in resolvers_settings.yaml)
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
